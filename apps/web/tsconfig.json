{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/src/*"],
      "@dapp/ui": ["../../packages/ui"],
      "@dapp/ui/*": ["../../packages/ui/*"],
      "@dapp/hooks": ["./app/src/hooks"],
      "@dapp/hooks/*": ["./app/src/hooks/*"],
      "@dapp/utils": ["./app/src/utils"],
      "@dapp/utils/*": ["./app/src/utils/*"],
      "@dapp/contracts": ["../../packages/contracts"],
      "@dapp/contracts/*": ["../../packages/contracts/*"],
      "@dapp/contexts": ["./app/src/contexts"],
      "@dapp/contexts/*": ["./app/src/contexts/*"],
      "@dapp/lib": ["./app/src/lib"],
      "@dapp/lib/*": ["./app/src/lib/*"]
    }
  },
  "include": [
    ".",
    "env.d.ts",
    "app/src/**/*"
  ]
}